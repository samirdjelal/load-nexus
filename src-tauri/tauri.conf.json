{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Load Nexus",
  "version": "0.1.3",
  "identifier": "com.samirdjelal.load-nexus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Load Nexus",
        "width": 900,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCMjUxMEJGQ0EyREE2ODUKUldTRnBpM0t2eEFsSzlGZDRWaXVIMGRaakR5UmUvY1NxMG44UTJSYzMyWHpCM3M0c1FvUnM2Y1cK",
      "endpoints": [
        "https://github.com/samirdjelal/load-nexus/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}